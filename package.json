{
  "name": "mimesis-sight-path",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "validate:objects": "node scripts/validate-object-registry.mjs",
    "validate:world-events": "node scripts/validate-world-events.mjs",
    "validate:live": "node scripts/validate-live-middleware.mjs",
    "validate:strict": "node --experimental-vm-modules scripts/validate-strict.mjs",
    "validate:card": "node scripts/validate-share-card.mjs",
    "validate:zone": "node scripts/validate-zone-system.mjs",
    "build": "npm run validate:objects && npm run validate:world-events && npm run validate:strict && npm run validate:card && npm run validate:zone && vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "@react-three/drei": "latest",
    "@react-three/fiber": "latest",
    "fbx2gltf": "^0.9.7-p1",
    "react": "latest",
    "react-dom": "latest",
    "three": "latest"
  },
  "devDependencies": {
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "@types/three": "latest",
    "@vitejs/plugin-react": "latest",
    "playwright": "^1.61.1",
    "typescript": "latest",
    "vite": "latest"
  }
}
