{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mimesis-byeoli-authority",
  "main": "src/index.ts",
  "compatibility_date": "2026-07-13",
  "durable_objects": {
    "bindings": [
      {
        "name": "BYEOLI_AUTHORITY",
        "class_name": "ByeoliAuthority"
      }
    ]
  },
  "migrations": [
    {
      "tag": "v1",
      "new_sqlite_classes": ["ByeoliAuthority"]
    }
  ],
  "observability": {
    "enabled": true
  }
}
